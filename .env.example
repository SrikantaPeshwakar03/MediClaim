# === Application ===
APP_NAME="MediClaim AI"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL="INFO"

# === API ===
API_V1_PREFIX="/api/v1"

# === Supabase ===
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-service-role-key"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_STORAGE_BUCKET="claim-documents"

# === LLM Configuration ===
# Provider options: openrouter, openai, anthropic, gemini, ollama
LLM_PROVIDER="openrouter"

# Your LLM API Key (not needed for Ollama)
LLM_API_KEY="sk-or-v1-your-key-here"

# Model name (format depends on provider)
# OpenRouter: "openai/gpt-4o-mini", "anthropic/claude-3-5-sonnet", etc.
# OpenAI: "gpt-4o", "gpt-4o-mini", "gpt-3.5-turbo"
# Anthropic: "claude-3-5-sonnet-20241022", "claude-3-opus-20240229"
# Gemini: "gemini-2.0-flash-exp", "gemini-1.5-pro"
# Ollama: "llama3.2", "mistral", "codellama"
LLM_MODEL="openai/gpt-4o-mini"

# Optional vision-capable model for handwritten / messy document extraction.
# When set, the OCRExtractor sends the document IMAGE directly to this model
# (better for handwriting) and can flag visual alterations/duplicate stamps.
# Leave empty to use the text-only OCR path (PaddleOCR + text LLM).
# Examples: "openai/gpt-4o" (OpenRouter), "gpt-4o" (OpenAI), "gemini-1.5-pro" (Gemini)
LLM_VISION_MODEL=""

# Optional: For Ollama only (local LLM server)
OLLAMA_BASE_URL="http://localhost:11434"

# === OCR Configuration ===
PADDLEOCR_LANG="en"
PADDLEOCR_USE_ANGLE_CLS=true
PADDLEOCR_USE_GPU=false
OCR_CONFIDENCE_THRESHOLD=0.5

# === Policy ===
POLICY_FILE_PATH="policy_terms.json"
